#!/bin/sh
# filogic-optimizer
# Boot-time performance and power configuration for Filogic-based routers.
# Runs once at boot via procd. Safe to re-run manually.
#
# WED flow offload is handled separately in:
#   /etc/hotplug.d/iface/20-filogic-wed-offload

log() { logger -t filogic-optimizer "$1"; }

# ── PCIe ASPM power saving ──────────────────────────────────────────────────
if [ -f /sys/module/pcie_aspm/parameters/policy ]; then
	echo powersave > /sys/module/pcie_aspm/parameters/policy
	log "PCIe ASPM: powersave"
fi

# ── Platform-specific: fan trip points ─────────────────────────────────────
# Detect via /proc/device-tree/compatible (kernel-owned, not world-writable).
# The file is NUL-delimited; -a treats it as text so grep matches across NULs.
THERMAL_BASE=/sys/devices/virtual/thermal/thermal_zone0
if grep -qaE "sdg-873[34]" /proc/device-tree/compatible 2>/dev/null; then
	log "SDG-8733/8733a/8734 detected: applying aggressive fan profile"
	echo 30000 > "$THERMAL_BASE/trip_point_5_temp"
	echo 32500 > "$THERMAL_BASE/trip_point_4_temp"
	echo 35000 > "$THERMAL_BASE/trip_point_3_temp"
	echo 40000 > "$THERMAL_BASE/trip_point_2_temp"
	echo 70000 > "$THERMAL_BASE/trip_point_1_temp"
	echo 75000 > "$THERMAL_BASE/trip_point_0_temp"
fi

# ── BBR qdisc pairing ─────────────────────────────────────────────────────
# BBR pairs best with fq (Fair Queue) for pacing; fq_codel's packet drops
# can interfere with BBR's bandwidth estimation. kmod-tcp-bbr already enables
# BBR via its own sysctl conf — we just set the optimal qdisc.
# Write sysctl.conf so fq applies at START=11 (before network at START=20),
# ensuring all interfaces get fq from creation.
BBR_FQ_CONF=/etc/sysctl.d/13-filogic-bbr-fq.conf
if [ "$(cat /proc/sys/net/ipv4/tcp_congestion_control 2>/dev/null)" = "bbr" ]; then
	echo "net.core.default_qdisc=fq" > "$BBR_FQ_CONF"
	echo fq > /proc/sys/net/core/default_qdisc
	log "TCP BBR detected: default qdisc set to fq"
else
	rm -f "$BBR_FQ_CONF"
fi

exit 0
